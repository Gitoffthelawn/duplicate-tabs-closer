{
  "manifest_version": 3,
  "name": "Duplicate Tabs Closer",
  "version": "4.2.7",
  "author": "Peuj",
  "default_locale": "en",
  "description": "Duplicate Tabs Closer",
  "icons": {
    "32": "images/auto_close_32.png",
    "128": "images/auto_close_128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "images/auto_close_16.png",
      "32": "images/auto_close_32.png"
    },
    "default_title": "Duplicate Tabs Closer",
    "default_popup": "popup/popup.html"
  },
  "permissions": [
    "tabs",
    "webNavigation",
    "storage"
  ],
  "commands": {
    "close-duplicate-tabs": {
      "description": "Close all duplicate tabs"
    },
    "toggle-close-mode": {
      "description": "Toggle between auto-close and manual mode"
    },
    "toggle-monitor-pause": {
      "description": "Pause or resume duplicate tab monitoring"
    }
  },
  "externally_connectable": {
    "_comment": "DEV ONLY — allows dtc-test companion extension to send messages. Remove or restrict to a specific extension ID before publishing to the Chrome Web Store.",
    "ids": ["*"]
  },
  "options_ui": {
    "page": "optionPage/optionPage.html",
    "open_in_tab": true
  }
}
